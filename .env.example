UNEMPLOYED_AI_API_KEY=
UNEMPLOYED_AI_BASE_URL=https://ai.automatedpros.link/v1
UNEMPLOYED_AI_MODEL=FelidaeAI-Pro-2.7
# Interview Helper uses these same shared AI values for live cue text,
# transient audio transcription, and screenshot vision unless a narrower
# UNEMPLOYED_INTERVIEW_* override is set.
# UNEMPLOYED_INTERVIEW_AI_MODEL=FelidaeAI-Pro-2.7
# UNEMPLOYED_INTERVIEW_VISION_MODEL=FelidaeAI-Omni-3.6
# Optional: generic resume-vision provider timeout in milliseconds (default: 600000 / 10 minutes).
# The text import path still completes gracefully if the provider times out.
# UNEMPLOYED_RESUME_VISION_TIMEOUT_MS=600000
# Optional: desktop image-adapter timeout in milliseconds (default: 600000); honored by local page image generation when set.
# UNEMPLOYED_RESUME_VISION_IMAGE_TIMEOUT_MS=600000

# Browser Agent — set to 1 to launch a dedicated Chrome profile for live browser-assisted discovery and supported apply flows
UNEMPLOYED_BROWSER_AGENT=1

# Optional: path to Chrome executable (auto-detected if unset)
# UNEMPLOYED_CHROME_PATH=

# Optional: Chrome debug port (default: 9333)
# UNEMPLOYED_CHROME_DEBUG_PORT=9333

# Optional: run Chrome headless (default: visible browser)
# UNEMPLOYED_BROWSER_HEADLESS=1
