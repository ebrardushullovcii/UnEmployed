{
  "name": "@unemployed/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint electron.vite.config.ts src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "ui:capture": "pnpm build && node ./scripts/capture-ui.mjs",
    "ui:resume-import": "pnpm build && node ./scripts/capture-resume-import.mjs"
  },
  "dependencies": {
    "@unemployed/ai-providers": "workspace:*",
    "@unemployed/browser-runtime": "workspace:*",
    "@unemployed/contracts": "workspace:*",
    "@unemployed/db": "workspace:*",
    "@unemployed/job-finder": "workspace:*",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^5.4.54",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-vite": "^3.1.0",
    "playwright": "^1.52.0",
    "vite": "^6.2.0"
  }
}

