{
  "name": "@unemployed/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "node ./scripts/prepare-resume-parser-sidecar.mjs --mode best-effort && electron-vite dev",
    "build": "node ./scripts/prepare-resume-parser-sidecar.mjs --mode best-effort && electron-vite build",
    "lint": "eslint electron.vite.config.ts src --ext .ts,.tsx",
    "prepare:resume-parser-sidecar": "node ./scripts/prepare-resume-parser-sidecar.mjs --mode required",
    "prepare:resume-parser-sidecar:matrix": "node ./scripts/prepare-resume-parser-sidecar.mjs --mode required --target win32-x64,darwin-arm64,darwin-x64,linux-x64",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "benchmark:resume-import": "pnpm build && node ./scripts/run-resume-import-benchmark.mjs",
    "ui:capture": "pnpm build && node ./scripts/capture-ui.mjs",
    "ui:profile-copilot-preferences": "pnpm build && node ./scripts/capture-profile-copilot-preferences.mjs",
    "ui:resume-import": "pnpm build && node ./scripts/capture-resume-import.mjs",
    "ui:profile-baseline": "pnpm build && node ./scripts/capture-profile-baseline.mjs",
    "ui:profile-setup": "pnpm build && node ./scripts/capture-profile-setup.mjs",
    "ui:applications-copilot-review": "pnpm build && node ./scripts/capture-applications-copilot-review.mjs",
    "ui:applications-recovery": "pnpm build && node ./scripts/capture-applications-recovery.mjs",
    "ui:applications-queue-recovery": "pnpm build && node ./scripts/capture-applications-queue-recovery.mjs",
    "ui:apply-queue-controls": "pnpm build && node ./scripts/capture-apply-queue-controls.mjs",
    "ui:resume-workspace": "pnpm build && node ./scripts/capture-resume-workspace.mjs",
    "ui:resume-workspace-dirty": "pnpm build && node ./scripts/capture-resume-workspace-dirty.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mozilla/readability": "^0.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@unemployed/ai-providers": "workspace:*",
    "@unemployed/browser-runtime": "workspace:*",
    "@unemployed/contracts": "workspace:*",
    "@unemployed/db": "workspace:*",
    "@unemployed/job-finder": "workspace:*",
    "@unemployed/knowledge-base": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "chromium-bidi": "^15.0.0",
    "clsx": "^2.1.1",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^5.4.54",
    "playwright": "^1.52.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.2.0"
  },
  "build": {
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/resume-parser-sidecar",
        "to": "resume-parser-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
