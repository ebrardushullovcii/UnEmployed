{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{js,mjs,ts}"
      ],
      "project": [
        "scripts/**/*.{js,mjs,ts}"
      ],
      "ignoreDependencies": [
        "dotenv"
      ]
    },
    "apps/desktop": {
      "entry": [
        "electron.vite.config.ts",
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/renderer/src/main.tsx",
        "scripts/**/*.{js,mjs,ts}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{js,mjs,ts}"
      ]
    },
    "packages/*": {
      "project": [
        "src/**/*.ts"
      ]
    }
  }
}
