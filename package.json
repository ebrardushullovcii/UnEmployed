{
  "name": "unemployed",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "turbo dev --parallel",
    "desktop:dev": "pnpm --filter @unemployed/desktop dev",
    "build": "turbo build",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "lint": "turbo lint",
    "structure:check": "node scripts/check-structure.mjs",
    "source-generic:check": "node scripts/check-source-generic-discovery.mjs",
    "hotspots": "node scripts/repo-hotspots.mjs",
    "lsp:typescript": "typescript-language-server --stdio",
    "typecheck": "turbo typecheck",
    "verify:quick": "pnpm docs:check && pnpm source-generic:check && pnpm structure:check && pnpm lint && pnpm typecheck",
    "verify:affected": "pnpm docs:check && pnpm source-generic:check && pnpm structure:check && turbo lint typecheck test --affected",
    "knip": "knip",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke": "vitest run --dir packages/contracts/src",
    "agents:sync": "node scripts/repo-context.mjs sync",
    "agents:check": "node scripts/repo-context.mjs check-agents",
    "docs:check": "node scripts/repo-context.mjs check-docs",
    "verify": "pnpm agents:check && pnpm docs:check && pnpm source-generic:check && pnpm structure:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.1.4",
    "dotenv": "^16.4.7",
    "eslint": "^9.22.0",
    "globals": "^14.0.0",
    "knip": "^6.4.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "typescript-language-server": "^4.4.0",
    "vitest": "^3.1.4",
    "yaml": "^2.8.0"
  }
}
